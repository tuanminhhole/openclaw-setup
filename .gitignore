# ===== Environment & Secrets =====
docker/openclaw/.env
*.env
*.env.*

# ===== Node =====
node_modules/

# ===== OpenClaw Runtime (generated by Docker/bot) =====
.openclaw/openclaw.json
.openclaw/openclaw.json.bak*
.openclaw/openclaw.json.clobbered*
.openclaw/update-check.json
.openclaw/config-audit.jsonl
.openclaw/config-health.json

# Sessions & Auth
.openclaw/sessions.json
.openclaw/auth-profiles.json

# Credentials & Identity (contains secrets)
.openclaw/credentials/
.openclaw/identity/
.openclaw/devices/

# Completions (shell autocomplete)
.openclaw/completions/

# Canvas
.openclaw/canvas/

# Agent runtime files
.openclaw/agents/*/agent/
.openclaw/agents/*/models.json
.openclaw/agents/*/auth-profiles.json
.openclaw/agents/*/*.sqlite

# Memory & Logs
.openclaw/memory/
.openclaw/logs/

# Workspace runtime state
.openclaw/workspace/workspace-state.json
.openclaw/workspace/BOOTSTRAP.md
.openclaw/workspace/HEARTBEAT.md

# ===== Temp / Debug files =====
*.txt
!SETUP*.txt
*.log

# ===== OS =====
.DS_Store
Thumbs.db
