# ============================================
# OpenClaw Docker Environment Variables
# ============================================
# Sao chép file này và đổi tên thành .env nếu cần
# Hoặc dùng wizard (index.html) để generate tự động
# ============================================

# === AI Provider API Key ===
# Nếu dùng 9Router: không cần điền (config qua 9Router dashboard)
# Nếu dùng trực tiếp: điền API key từ provider
# OPENAI_API_KEY=sk-your-key-here
# GEMINI_API_KEY=your-gemini-key-here

# === Channel Token ===
# Telegram: lấy từ @BotFather
# TELEGRAM_BOT_TOKEN=your-telegram-token

# === Gateway ===
# OPENCLAW_GATEWAY_TOKEN=auto-generated-by-wizard
